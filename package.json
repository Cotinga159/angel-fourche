{
  "name": "angel-fourche",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
  "start": "node --env-file=.env src/app.js",
  "start:prod": "node --env-file=.env.prod src/app.js",
  "dev": "node --env-file=.env --watch src/app.js",
  "db:migrate": "node --env-file=.env database/migrations/runAll.js",
  "db:migrate:prod": "node --env-file=.env.prod database/migrations/runAll.js",
  "db:nuke": "node --env-file=.env database/migrations/nukeAll.js",
  "db:nuke:prod": "node --env-file=.env.prod database/migrations/nukeAll.js",
  "gen:secrets": "node ./scripts/gen-secrets.js",
  "gen:secrets:prod": "node ./scripts/gen-secrets.js --prod"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-sync": "^4.2.1",
    "dotenv": "^17.2.3",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "pg": "^8.17.1",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "vitest": "^4.0.18"
  }
}
