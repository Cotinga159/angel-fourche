<button class="burger-btn" id="burger-btn">
    <span></span>
    <span></span>
    <span></span>
</button>

<ul class="authentification">
    <label class="switch">
    <input type="checkbox" id="theme-toggle" />
    <span class="slider"></span>
    </label>
    <% if (!locals.currentUser) { %>
        <li><a href="/auth/register">S'inscrire</a></li>
    <% } %>
    <% if (locals.currentUser) { %>
        <li>
            <form action="/auth/logout" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit">Se déconnecter</button>
            </form>
        </li>
    <% } else { %>
        <li><a href="/auth/login">Se connecter</a></li>
    <% } %>
</ul>

<ul class="menu">
    <li>
        <div class="logo">
            <a href="/"><img src="/images/logo.svg" alt="Logo"></a>
        </div>
    </li>
    <li><a href="/">Accueil</a></li>
    <% if (locals.currentUser) { %>
        <li><a href="/users">Profile</a></li>
    <% } %>
    <li><a href="/recipes">Recette</a></li>
    
    <li class="search-desktop">
        <form action="/recipes/search" method="GET">
            <button type="submit">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                    <path fill="rgb(255, 255, 255)" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z"/>
                </svg>
            </button>
            <input type="text" name="q" placeholder="Rechercher une recette..."
                value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
        </form>
    </li>
    <li class="search-mobile">
        <button class="search-toggle" id="search-toggle" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="20" height="20">
                <path fill="rgb(255, 255, 255)" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z"/>
            </svg>
        </button>
    </li>

</ul>

<!-- EN DEHORS des ul -->
<div class="search-bar-dropdown" id="search-bar-dropdown">
    <form action="/recipes/search" method="GET" class="search-bar-form">
        <input type="text" name="q" placeholder="Rechercher une recette..."
            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
        <button type="submit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="20" height="20">
                <path fill="rgb(255, 255, 255)" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z"/>
            </svg>
        </button>
    </form>
</div>

<script>
document.getElementById('burger-btn').addEventListener('click', () => {
    const menu = document.querySelector('nav .menu');
    const auth = document.querySelector('nav .authentification');
    
    menu.classList.toggle('open');
    auth.classList.toggle('open');
    
    if (!menu.classList.contains('open')) {
        document.getElementById('search-bar-dropdown').classList.remove('open');
    }
});

const searchToggle = document.getElementById('search-toggle');
if (searchToggle) {
    searchToggle.addEventListener('click', () => {
        document.getElementById('search-bar-dropdown').classList.toggle('open');
    });
}
const toggle = document.getElementById('theme-toggle');

// Au chargement, restaure le thème
const savedTheme = localStorage.getItem('theme') || 'light';
document.documentElement.setAttribute('data-theme', savedTheme);
toggle.checked = savedTheme === 'light';

// Au changement
toggle.addEventListener('change', () => {
        const isDark = !toggle.checked;
    document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
});
</script>