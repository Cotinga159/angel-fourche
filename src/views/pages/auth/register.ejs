<main class="login-container">
    <h1>Inscription</h1>

    <% if (locals.error) { %>
        <p class="error"><%= locals.error %></p>
    <% } %>

    <form action="/auth/register" method="POST" class="login-card">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-row">
            <label>Nom d'utilisateur</label>
            <input type="text" name="nameUser"
                value="<%= locals.formData ? locals.formData.nameUser : '' %>" required>
        </div>

        <div class="form-row">
            <label>Email</label>
            <input type="email" name="email"
                value="<%= locals.formData ? locals.formData.email : '' %>" required>
        </div>

        <div class="form-row">
            <label>Mot de passe</label>
            <input type="password" name="password" required>
        </div>

        <div class="form-row">
            <label>Enter à nouveau le mot de passe</label>
            <input type="password" name="passwordConfirm" required>
        </div>

        <div class="form-checkbox">
            <input type="checkbox" name="gdprConsent" value="true" required>
            <span>J'accepte les conditions</span>
        </div>

        <button type="submit">S'inscrire</button>
    </form>

    <p class="redirect">
        Déjà un compte ? <a href="/auth/login">Se connecter</a>
    </p>
</main>