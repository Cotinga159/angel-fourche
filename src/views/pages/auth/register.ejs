<main class="login-container">
    <h1>Inscription</h1>

    <% if (locals.error) { %>
        <p class="error"><%= locals.error %></p>
    <% } %>

    <form action="/auth/register" method="POST" class="login-card">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

<div class="form-row">
    <div class="input-field">
        <input type="text" name="nameUser" id="nameUser" placeholder=" "
            value="<%= locals.formData ? locals.formData.nameUser : '' %>"
            required autocomplete="off">
        <label for="nameUser">Nom d'utilisateur</label>
    </div>
</div>

<div class="form-row">
    <div class="input-field">
        <input type="email" name="email" id="email" placeholder=" "
            value="<%= locals.formData ? locals.formData.email : '' %>"
            required autocomplete="off">
        <label for="email">Email</label>
    </div>
</div>

  <div class="form-row">
    <fieldset class="input-fieldset">
        <legend>Mot de passe</legend>
       <div class="input-wrapper">
    <input type="password" name="password" required minlength="8"
        pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&amp;*()_+\-=\[\]{};':&quot;|,.\/?]).{8,}"
        title="Au moins 8 caractères, une majuscule, une minuscule, un chiffre et un caractère spécial">
    <label class="container">
        <input type="checkbox" class="toggle-password" data-target="password">
        <svg class="eye" xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 576 512"><path d="M288 32c-80.8 0-145.5 36.8-192.6 80.6C48.6 156 17.3 208 2.5 243.7c-3.3 7.9-3.3 16.7 0 24.6C17.3 304 48.6 356 95.4 399.4C142.5 443.2 207.2 480 288 480s145.5-36.8 192.6-80.6c46.8-43.5 78.1-95.4 93-131.1c3.3-7.9 3.3-16.7 0-24.6c-14.9-35.7-46.2-87.7-93-131.1C433.5 68.8 368.8 32 288 32zM144 256a144 144 0 1 1 288 0 144 144 0 1 1 -288 0zm144-64c0 35.3-28.7 64-64 64c-7.1 0-13.9-1.2-20.3-3.3c-5.5-1.8-11.9 1.6-11.7 7.4c.3 6.9 1.3 13.8 3.2 20.7c13.7 51.2 66.4 81.6 117.6 67.9s81.6-66.4 67.9-117.6c-11.1-41.5-47.8-69.4-88.6-71.1c-5.8-.2-9.2 6.1-7.4 11.7c2.1 6.4 3.3 13.2 3.3 20.3z"></path></svg>
         <svg class="eye-slash" xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 640 512"><path d="M38.8 5.1C28.4-3.1 13.3-1.2 5.1 9.2S-1.2 34.7 9.2 42.9l592 464c10.4 8.2 25.5 6.3 33.7-4.1s6.3-25.5-4.1-33.7L525.6 386.7c39.6-40.6 66.4-86.1 79.9-118.4c3.3-7.9 3.3-16.7 0-24.6c-14.9-35.7-46.2-87.7-93-131.1C465.5 68.8 400.8 32 320 32c-68.2 0-125 26.3-169.3 60.8L38.8 5.1zM223.1 149.5C248.6 126.2 282.7 112 320 112c79.5 0 144 64.5 144 144c0 24.9-6.3 48.3-17.4 68.7L408 294.5c8.4-19.3 10.6-41.4 4.8-63.3c-11.1-41.5-47.8-69.4-88.6-71.1c-5.8-.2-9.2 6.1-7.4 11.7c2.1 6.4 3.3 13.2 3.3 20.3c0 10.2-2.4 19.8-6.6 28.3l-90.3-70.8zM373 389.9c-16.4 6.5-34.3 10.1-53 10.1c-79.5 0-144-64.5-144-144c0-6.9 .5-13.6 1.4-20.2L83.1 161.5C60.3 191.2 44 220.8 34.5 243.7c-3.3 7.9-3.3 16.7 0 24.6c14.9 35.7 46.2 87.7 93 131.1C174.5 443.2 239.2 480 320 480c47.8 0 89.9-12.9 126.2-32.5L373 389.9z"></path></svg>
    </label>
</div>
    </fieldset>
</div>

<div class="form-row">
    <fieldset class="input-fieldset">
        <legend>Confirmer le mot de passe</legend>
       <div class="input-wrapper">
    <input type="password" name="passwordConfirm" required>
    <label class="container">
        <input type="checkbox" class="toggle-password" data-target="passwordConfirm">
        <svg class="eye" xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 576 512"><path d="M288 32c-80.8 0-145.5 36.8-192.6 80.6C48.6 156 17.3 208 2.5 243.7c-3.3 7.9-3.3 16.7 0 24.6C17.3 304 48.6 356 95.4 399.4C142.5 443.2 207.2 480 288 480s145.5-36.8 192.6-80.6c46.8-43.5 78.1-95.4 93-131.1c3.3-7.9 3.3-16.7 0-24.6c-14.9-35.7-46.2-87.7-93-131.1C433.5 68.8 368.8 32 288 32zM144 256a144 144 0 1 1 288 0 144 144 0 1 1 -288 0zm144-64c0 35.3-28.7 64-64 64c-7.1 0-13.9-1.2-20.3-3.3c-5.5-1.8-11.9 1.6-11.7 7.4c.3 6.9 1.3 13.8 3.2 20.7c13.7 51.2 66.4 81.6 117.6 67.9s81.6-66.4 67.9-117.6c-11.1-41.5-47.8-69.4-88.6-71.1c-5.8-.2-9.2 6.1-7.4 11.7c2.1 6.4 3.3 13.2 3.3 20.3z"></path></svg>
        <svg class="eye-slash" xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 640 512"><path d="M38.8 5.1C28.4-3.1 13.3-1.2 5.1 9.2S-1.2 34.7 9.2 42.9l592 464c10.4 8.2 25.5 6.3 33.7-4.1s6.3-25.5-4.1-33.7L525.6 386.7c39.6-40.6 66.4-86.1 79.9-118.4c3.3-7.9 3.3-16.7 0-24.6c-14.9-35.7-46.2-87.7-93-131.1C465.5 68.8 400.8 32 320 32c-68.2 0-125 26.3-169.3 60.8L38.8 5.1zM223.1 149.5C248.6 126.2 282.7 112 320 112c79.5 0 144 64.5 144 144c0 24.9-6.3 48.3-17.4 68.7L408 294.5c8.4-19.3 10.6-41.4 4.8-63.3c-11.1-41.5-47.8-69.4-88.6-71.1c-5.8-.2-9.2 6.1-7.4 11.7c2.1 6.4 3.3 13.2 3.3 20.3c0 10.2-2.4 19.8-6.6 28.3l-90.3-70.8zM373 389.9c-16.4 6.5-34.3 10.1-53 10.1c-79.5 0-144-64.5-144-144c0-6.9 .5-13.6 1.4-20.2L83.1 161.5C60.3 191.2 44 220.8 34.5 243.7c-3.3 7.9-3.3 16.7 0 24.6c14.9 35.7 46.2 87.7 93 131.1C174.5 443.2 239.2 480 320 480c47.8 0 89.9-12.9 126.2-32.5L373 389.9z"></path></svg>
    </label>
</div>
    </fieldset>
</div>

        <div class="form-checkbox">
            <input type="checkbox" name="gdprConsent" value="true" required>
            <span>J'accepte les conditions</span>
        </div>

        <button type="submit">S'inscrire</button>
    </form>

    <p class="redirect">
        Déjà un compte ? <a href="/auth/login">Se connecter</a>
    </p>
</main>
<script>
    const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]).{8,}$/;

const checkIcon = "url('/images/check.svg')";
const crossIcon = "url('/images/xmark.svg')";

function setCheck(input, valid) {
    if (!input.value) {
        input.style.backgroundImage = "";
        input.style.paddingRight = "";
        return;
    }
    input.style.backgroundImage = valid ? checkIcon : crossIcon;
    input.style.backgroundRepeat = "no-repeat";
    input.style.backgroundSize = "18px";

    const inFieldset = input.closest('.input-fieldset');
    input.style.backgroundPosition = inFieldset ? "right 40px center" : "right 8px center";
    input.style.paddingRight = inFieldset ? "64px" : "32px";
}

// Nom d'utilisateur — au moins 3 caractères
const nameUser = document.querySelector('input[name="nameUser"]');
nameUser.addEventListener("input", () => {
    setCheck(nameUser, nameUser.value.trim().length >= 3);
});

// Email — format valide
const email = document.querySelector('input[name="email"]');
email.addEventListener("input", () => {
    setCheck(email, /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value));
});

// Mot de passe
const password = document.querySelector('input[name="password"]');
password.addEventListener("input", () => {
    const valid = passwordRegex.test(password.value);
    console.log("valid:", valid);
    setCheck(password, valid);
    console.log("backgroundImage:", password.style.backgroundImage);
    if (passwordConfirm.value) {
        setCheck(passwordConfirm, passwordConfirm.value === password.value);
    }
});

// Confirmation mot de passe
const passwordConfirm = document.querySelector('input[name="passwordConfirm"]');
passwordConfirm.addEventListener("input", () => {
    setCheck(passwordConfirm, passwordConfirm.value === password.value && passwordConfirm.value !== "");
});

// Rendre visible le mots de passe
document.querySelectorAll(".toggle-password").forEach(checkbox => {
    checkbox.addEventListener("change", () => {
        const input = document.querySelector(`input[name="${checkbox.dataset.target}"]`);
        input.type = checkbox.checked ? "text" : "password";
    });
});

</script>