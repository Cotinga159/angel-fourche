<main class="login-container">
    <h1>Connexion</h1>
    <% if (locals.flash && locals.flash.error) { %>
        <p class="error"><%= locals.flash.error %></p>
    <% } %>
    <form action="/auth/login" method="POST" class="login-card">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-row">
            <div class="input-field">
                <input type="text" name="email" id="loginEmail" placeholder=" " required autocomplete="off">
                <label for="loginEmail">Email ou nom d'utilisateur</label>
            </div>
        </div>
        <div class="form-row">
            <fieldset class="input-fieldset">
                <legend>Mot de passe</legend>
                <div class="input-wrapper">
                    <input type="password" name="password" required>
                </div>
            </fieldset>
        </div>
        <button type="submit">Se connecter</button>
    </form>
    <p class="redirect">
        Pas encore de compte ? <a href="/auth/register">S'inscrire</a>
    </p>
</main>