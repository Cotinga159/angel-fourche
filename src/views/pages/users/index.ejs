<main class="user-index">
    <% if (currentUser) { %>
        
        <h1>Mon profil</h1>
        <div class="user-container">
            <div class="user-profil">
                <h3>Informations personnelles</h3>
                <p>Pseudo : <%= currentUser.nameUser %></p>
                <p>Email : <%= currentUser.email %></p>
                <a href="/users/edit">
                    <button>Modifier mon profil</button>
                </a>
                <form action="/users/delete" method="POST" id="delete-account-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" id="delete-btn">Supprimer mon compte</button>
                </form>
            </div>
            <div class="user-stat">
                <h3>Stats</h3>
                <p>Recettes publiées : <%= myRecipesCount > 0 ? myRecipesCount : 'Aucune' %></p>
                <p>Recettes aimées : <%= myFavoritesCount > 0 ? myFavoritesCount : 'Aucune' %></p>
                <p>Recettes notées : <%= myRatingsCount > 0 ? myRatingsCount : 'Aucune' %></p>
                <p>Commentaires publiés : <%= myCommentsCount > 0 ? myCommentsCount : 'Aucun' %></p>
            </div>
        </div>

        <div class="create-recipe-btn-wrapper">
            <a href="/recipes/new">
                <button class="button-create-recipe">Créer une recette</button>
            </a>
        </div>

    <% } else { %>
        <p>Utilisateur non connecté.</p>
    <% } %>

    <!-- Mes recettes publiées -->
    <h2>Mes recettes publiées</h2>
    <% if (recipes && recipes.length > 0) { %>
        <div class="my-recipes-wrapper">
            <% recipes.forEach(recipe => { %>
                <div class="my-recipe-card">
                    <a href="/recipes/<%= recipe.id %>">
                        <img src="<%= recipe.picture %>" alt="<%= recipe.title %>" class="card-img">
                        <h3><%= recipe.title %></h3>
                        <div class="recipe-info">
                            <div class="recipe-info-bar">
                                <div class="card-counters">
                                    <div class="counter-item">
                                        <img src="./images/heart_complet.svg" alt="">
                                        <span><%= recipe.favoritesCount ?? 0 %></span>
                                    </div>
                                    <div class="counter-item">
                                        <img src="./images/comment.svg" alt="">
                                        <span><%= recipe.commentsCount ?? 0 %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
              <div class="my-recipe-actions">
    <a href="/recipes/<%= recipe.id %>/edit">
        <button>Modifier</button>
    </a>
    <form action="/recipes/<%= recipe.id %>/delete" method="POST" class="delete-recipe-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit"><img src="./images/trash.svg" alt="Supprimer"></button>
    </form>
</div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p>Vous n'avez pas encore publié de recette.</p>
    <% } %>

    <!-- Mes favoris -->
    <h2>Mes recettes favorites</h2>
    <% if (favorites && favorites.length > 0) { %>
        <div class="my-favorites-wrapper">
            <% favorites.forEach(recipe => { %>
               <div class="my-favorite-card">
    <a href="/recipes/<%= recipe.id_recipe %>">
        <img src="<%= recipe.picture %>" alt="<%= recipe.title %>" class="card-img">
        <h3><%= recipe.title %></h3>
    </a>
    <% if (currentUser) { %>
        <div class="con-like">
            <input 
                class="like no-animate" 
                type="checkbox" 
                checked
                data-recipe-id="<%= recipe.id_recipe %>">
            <div class="checkmark">
                <svg xmlns="http://www.w3.org/2000/svg" class="background" viewBox="0 0 24 24">
                    <path d="M17.5,1.917a6.4,6.4,0,0,0-5.5,3.3,6.4,6.4,0,0,0-5.5-3.3A6.8,6.8,0,0,0,0,8.967c0,4.547,4.786,9.513,8.8,12.88a4.974,4.974,0,0,0,6.4,0C19.214,18.48,24,13.514,24,8.967A6.8,6.8,0,0,0,17.5,1.917Z"></path>
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="outline" viewBox="0 0 24 24">
                    <path d="M17.5,1.917a6.4,6.4,0,0,0-5.5,3.3,6.4,6.4,0,0,0-5.5-3.3A6.8,6.8,0,0,0,0,8.967c0,4.547,4.786,9.513,8.8,12.88a4.974,4.974,0,0,0,6.4,0C19.214,18.48,24,13.514,24,8.967A6.8,6.8,0,0,0,17.5,1.917Zm-3.585,18.4a2.973,2.973,0,0,1-3.83,0C4.947,16.006,2,11.87,2,8.967a4.8,4.8,0,0,1,4.5-5.05A4.8,4.8,0,0,1,11,8.967a1,1,0,0,0,2,0,4.8,4.8,0,0,1,4.5-5.05A4.8,4.8,0,0,1,22,8.967C22,11.87,19.053,16.006,13.915,20.313Z"></path>
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="filled" viewBox="0 0 24 24">
                    <path d="M17.5,1.917a6.4,6.4,0,0,0-5.5,3.3,6.4,6.4,0,0,0-5.5-3.3A6.8,6.8,0,0,0,0,8.967c0,4.547,4.786,9.513,8.8,12.88a4.974,4.974,0,0,0,6.4,0C19.214,18.48,24,13.514,24,8.967A6.8,6.8,0,0,0,17.5,1.917Z"></path>
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" height="100" width="100" class="celebrate">
                    <polygon class="poly" points="10,10 20,20"></polygon>
                    <polygon class="poly" points="10,50 20,50"></polygon>
                    <polygon class="poly" points="20,80 30,70"></polygon>
                    <polygon class="poly" points="90,10 80,20"></polygon>
                    <polygon class="poly" points="90,50 80,50"></polygon>
                    <polygon class="poly" points="80,80 70,70"></polygon>
                </svg>
            </div>
        </div>
    <% } %>
</div>
            <% }) %>
        </div>
    <% } else { %>
        <p>Vous n'avez pas encore de recette favorite.</p>
    <% } %>

    <script>
        document.getElementById('delete-account-form').addEventListener('submit', function(e) {
            if (!confirm('Êtes-vous sûr de vouloir supprimer votre compte ? Cette action est irréversible.')) {
                e.preventDefault();
            }
        });
        document.querySelectorAll('.delete-recipe-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                if (!confirm('Êtes-vous sûr de vouloir supprimer cette recette ? Cette action est irréversible.')) {
                    e.preventDefault();
                }
            });
        });

        // Favoris page profil
document.querySelectorAll('.my-favorites-wrapper .like').forEach(input => {
    input.addEventListener('change', async (e) => {
        input.classList.remove('no-animate');
        const recipeId = input.dataset.recipeId;
        try {
            await fetch(`/favorites/${recipeId}`, {
                method: 'POST',
                headers: { 'Accept': 'application/json' }
            });
            // Si décoché, retire la carte après animation
            if (!input.checked) {
                setTimeout(() => {
                    input.closest('.my-favorite-card').remove();
                }, 400);
            }
        } catch (err) {
            console.error('Erreur favori:', err);
            input.checked = !input.checked;
        }
    });
});
    </script>
</main>