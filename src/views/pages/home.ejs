<!-- src/views/pages/home.ejs -->

<header>
    <h1>Bienvenue sur Angel Fourche</h1>
    <p>Chaque recette raconte une histoire. Partagez la vôtre.</p>
</header>

<main>
    
    <!-- Recettes les plus mises en favoris cette semaine -->
    <section>
        <div class="home-favorite-title">
            <img src="./images/heart_complet.svg" alt=""  width="30">
            <h2>Les recettes favorites de cette semaine</h2>
        </div>
        <div class="favorite-recipes-container">
        <% if (topFavorites && topFavorites.length > 0) { %>
            <div class="favorite-recipes-wrapper">
                <% topFavorites.forEach(recipe => { %>
                <div class="recipe-favorite-card">
    <a href="/recipes/<%= recipe.id %>">
        <img src="<%= recipe.picture %>" alt="<%= recipe.title %>">
        <h3><%= recipe.title %></h3>
        <div class="recipe-info">
    <div class="recipe-info-bar">
        <div class="difficulty">
            <% 
            const levels = { 'Facile': 1, 'Moyen': 2, 'Difficile': 3 };
            const currentLevel = levels[recipe.difficulty] || 1;
            %>
            <% for(let i = 1; i <= 3; i++) { %>
                <span class="flame-icon <%= i <= currentLevel ? 'active' : 'inactive' %>">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="20" height="20">
                        <path d="M256.5 37.6C265.8 29.8 279.5 30.1 288.4 38.5C300.7 50.1 311.7 62.9 322.3 75.9C335.8 92.4 352 114.2 367.6 140.1C372.8 133.3 377.6 127.3 381.8 122.2C382.9 120.9 384 119.5 385.1 118.1C393 108.3 402.8 96 415.9 96C429.3 96 438.7 107.9 446.7 118.1C448 119.8 449.3 121.4 450.6 122.9C460.9 135.3 474.6 153.2 488.3 175.3C515.5 219.2 543.9 281.7 543.9 351.9C543.9 475.6 443.6 575.9 319.9 575.9C196.2 575.9 96 475.7 96 352C96 260.9 137.1 182 176.5 127C196.4 99.3 216.2 77.1 231.1 61.9C239.3 53.5 247.6 45.2 256.6 37.7zM321.7 480C347 480 369.4 473 390.5 459C432.6 429.6 443.9 370.8 418.6 324.6C414.1 315.6 402.6 315 396.1 322.6L370.9 351.9C364.3 359.5 352.4 359.3 346.2 351.4C328.9 329.3 297.1 289 280.9 268.4C275.5 261.5 265.7 260.4 259.4 266.5C241.1 284.3 207.9 323.3 207.9 370.8C207.9 439.4 258.5 480 321.6 480z"/>
                    </svg>
                </span>
            <% } %>
        </div>
        <div class="favorites-count">
            <img src="./images/heart_complet.svg" alt="" width="14">
            <span><%= recipe.favoritesCount %></span>
        </div>
    </div>
</div>
    </a>
</div>
                <% }) %>
            </div>
        <% } else { %>
            <p>Aucune recette cette semaine.</p>
        <% } %>
        </div>
    </section>

    <!-- Recettes les mieux notées -->
    <section>
    <div class="top-rated-title">
        <img src="./images/star_complete.svg" alt="" width="30">
        <h2>Les mieux notées</h2>
    </div>
    <% if (topRated && topRated.length > 0) { %>
        <div class="top-rated-wrapper">
            <% topRated.forEach((recipe, index) => { %>
                <% if (index % 3 === 1) { %> <%# ouvre le groupe double %>
                    <div class="top-rated-double">
                <% } %>

                <div class="top-rated-card <%= index % 3 === 0 || index % 3 === 2 ? 'single' : 'half' %>">
                    <a href="/recipes/<%= recipe.id %>">
                        <img src="<%= recipe.picture %>" alt="<%= recipe.title %>">
                        <h3><%= recipe.title %></h3>
                        <div class="recipe-info">
                            <div class="recipe-info-bar">
                                <div class="difficulty">
                                    <% 
                                    const levels = { 'Facile': 1, 'Moyen': 2, 'Difficile': 3 };
                                    const currentLevel = levels[recipe.difficulty] || 1;
                                    %>
                                    <% for(let i = 1; i <= 3; i++) { %>
                                        <span class="flame-icon <%= i <= currentLevel ? 'active' : 'inactive' %>">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="20" height="20">
                                                <path d="M256.5 37.6C265.8 29.8 279.5 30.1 288.4 38.5C300.7 50.1 311.7 62.9 322.3 75.9C335.8 92.4 352 114.2 367.6 140.1C372.8 133.3 377.6 127.3 381.8 122.2C382.9 120.9 384 119.5 385.1 118.1C393 108.3 402.8 96 415.9 96C429.3 96 438.7 107.9 446.7 118.1C448 119.8 449.3 121.4 450.6 122.9C460.9 135.3 474.6 153.2 488.3 175.3C515.5 219.2 543.9 281.7 543.9 351.9C543.9 475.6 443.6 575.9 319.9 575.9C196.2 575.9 96 475.7 96 352C96 260.9 137.1 182 176.5 127C196.4 99.3 216.2 77.1 231.1 61.9C239.3 53.5 247.6 45.2 256.6 37.7zM321.7 480C347 480 369.4 473 390.5 459C432.6 429.6 443.9 370.8 418.6 324.6C414.1 315.6 402.6 315 396.1 322.6L370.9 351.9C364.3 359.5 352.4 359.3 346.2 351.4C328.9 329.3 297.1 289 280.9 268.4C275.5 261.5 265.7 260.4 259.4 266.5C241.1 284.3 207.9 323.3 207.9 370.8C207.9 439.4 258.5 480 321.6 480z"/>
                                            </svg>
                                        </span>
                                    <% } %>
                                </div>
                                <div class="rating-count">
                                    <img src="./images/star_complete.svg" alt="" width="14">
                                    <span><%= recipe.averageRating %> / 5</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                <% if (index % 3 === 2) { %> <%# ferme le groupe double %>
                    </div>
                <% } %>
            <% }) %>
        </div>
    <% } else { %>
        <p>Aucune recette notée pour le moment.</p>
    <% } %>
</section>

    <!-- Meilleures recettes par catégorie -->
    <section>
    <div class="best-categorie-title">
        <img src="./images/trophy.svg" alt="" width="30">
        <h2>Les meilleures par catégorie</h2>
        </div>
        <% if (topByCategory && topByCategory.length > 0) { %>
            <div class="best-categorie-wrapper">
    <% topByCategory.forEach(recipe => { %>
    <div class="best-categorie-card">
    <a href="/recipes/<%= recipe.id %>">
        <img src="<%= recipe.picture %>" alt="<%= recipe.title %>">
        <h3><%= recipe.title %></h3>
        <div class="recipe-info">
            <div class="difficulty">
                <% 
                const levels = { 'Facile': 1, 'Moyen': 2, 'Difficile': 3 };
                const currentLevel = levels[recipe.difficulty] || 1;
                %>
                <% for(let i = 1; i <= 3; i++) { %>
                    <span class="flame-icon <%= i <= currentLevel ? 'active' : 'inactive' %>">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="20" height="20">
                            <path d="M256.5 37.6C265.8 29.8 279.5 30.1 288.4 38.5C300.7 50.1 311.7 62.9 322.3 75.9C335.8 92.4 352 114.2 367.6 140.1C372.8 133.3 377.6 127.3 381.8 122.2C382.9 120.9 384 119.5 385.1 118.1C393 108.3 402.8 96 415.9 96C429.3 96 438.7 107.9 446.7 118.1C448 119.8 449.3 121.4 450.6 122.9C460.9 135.3 474.6 153.2 488.3 175.3C515.5 219.2 543.9 281.7 543.9 351.9C543.9 475.6 443.6 575.9 319.9 575.9C196.2 575.9 96 475.7 96 352C96 260.9 137.1 182 176.5 127C196.4 99.3 216.2 77.1 231.1 61.9C239.3 53.5 247.6 45.2 256.6 37.7zM321.7 480C347 480 369.4 473 390.5 459C432.6 429.6 443.9 370.8 418.6 324.6C414.1 315.6 402.6 315 396.1 322.6L370.9 351.9C364.3 359.5 352.4 359.3 346.2 351.4C328.9 329.3 297.1 289 280.9 268.4C275.5 261.5 265.7 260.4 259.4 266.5C241.1 284.3 207.9 323.3 207.9 370.8C207.9 439.4 258.5 480 321.6 480z"/>
                        </svg>
                    </span>
                <% } %>
            </div>
            <div class="category-bar">
                <div class="category-name">
                    <img src="./images/trophy.svg" alt="" width="14">
                    <span><%= recipe.category ? recipe.category.name : '' %></span>
                </div>
                <div class="rating-count">
                    <img src="./images/star_complete.svg" alt="" width="14">
                    <span><%= recipe.averageRating ?? 'N/A' %></span>
                </div>
            </div>
        </div>
    </a>
</div>
    <% }) %>
</div>
        <% } else { %>
            <p>Aucune recette pour le moment.</p>
        <% } %>
    </section>
</main>


