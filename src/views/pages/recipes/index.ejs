<% recipes.forEach(recipe => { %>
    <a href="/recipes/<%= recipe.id %>">
        <div class="recipe-card">
            <h2><%= recipe.title %></h2>

            <p>Difficulté: <%= recipe.difficulty %></p>
            <% if (recipe.picture) { %>
                <img src="<%= recipe.picture %>" alt="<%= recipe.title %>" width="300">
            <% } %>
        </div>
    </a>
    <span class="stars">
    <% for(let i = 1; i <= 5; i++) { %>
        <% if(i <= Math.round(recipe.averageRating)) { %>
            <span class="star full">★</span>
        <% } else { %>
            <span class="star empty">☆</span>
        <% } %>
    <% } %>
</span>
<% if (user) { %>
    <button 
        class="favorite-btn" 
        data-recipe-id="<%= recipe.id %>"
        data-favorite="<%= favoriteIds.includes(recipe.id) %>">
        <%= favoriteIds.includes(recipe.id) ? '❤️' : '🤍' %>
    </button>
<% } %>

<% }) %>
<script>
    document.querySelectorAll('.favorite-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const recipeId = btn.dataset.recipeId;
            
            try {
                await fetch(`/favorites/${recipeId}`, { 
    method: 'POST',
    headers: { 'Accept': 'application/json' }
});
                
                const isFav = btn.dataset.favorite === 'true';
                btn.dataset.favorite = String(!isFav);
                btn.textContent = !isFav ? '❤️' : '🤍';
            } catch (err) {
                console.error('Erreur favori:', err);
            }
        });
    });
</script>